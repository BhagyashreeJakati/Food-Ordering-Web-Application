# Copy this file to .env and fill in your values
# Never commit .env to version control

# Database
DB_URL=jdbc:mysql://localhost:3306/food_ordering_system?createDatabaseIfNotExist=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT — generate a strong random string (min 64 chars)
JWT_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-64-characters-long

# Razorpay
RAZORPAY_KEY=rzp_test_your_key_here
RAZORPAY_SECRET=your_razorpay_secret_here

# Gmail SMTP
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# App URL
APP_BASE_URL=http://localhost:3000
